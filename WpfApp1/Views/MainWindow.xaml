<Window x:Class="WpfApp1.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1" 
        xmlns:views="clr-namespace:WpfApp1.Views"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <StackPanel VerticalAlignment="Center">

        <views:ColorStatusCard 
            CardBrush="{Binding BoxColor}" 
            CardName="{Binding BoxColorName}"
            Width="250" 
            Height="150" 
            Margin="20"
        />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="빨강" Width="60" Margin="5"
                    Command="{Binding ChangeColorCommand}" CommandParameter="Red"/>
            <Button Content="초록" Width="60" Margin="5"
                    Command="{Binding ChangeColorCommand}" CommandParameter="Green"/>
            <Button Content="파랑" Width="60" Margin="5"
                    Command="{Binding ChangeColorCommand}" CommandParameter="Blue"/>
        </StackPanel>

    </StackPanel>
</Window>
