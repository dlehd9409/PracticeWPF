<UserControl x:Class="WpfApp1.Views.ColorStatusCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="ParentControl">
    <Grid>
        <Border BorderBrush="{Binding CardBrush, ElementName=ParentControl}" 
                BorderThickness="8" 
                CornerRadius="15" 
                Background="White"
                Padding="20" Margin="10">

            <StackPanel VerticalAlignment="Center">
                <Ellipse Fill="{Binding CardBrush, ElementName=ParentControl}" 
                         Width="20" Height="20" 
                         Margin="0,10,0,0"/>
                <TextBlock Text="{Binding CardName, ElementName=ParentControl}" 
               Foreground="{Binding CardBrush, ElementName=ParentControl}" 
               FontSize="20"
               FontWeight="Bold"
               HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>